# ==========================================
# BACKEND ENVIRONMENT VARIABLES (.env)
# These are required for Render deployment
# ==========================================

# 1. Database Connection (From Aiven/PlanetScale/Supabase)
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?sslaccept=strict"

# 2. JWT Secrets (Generate secure random strings)
JWT_ACCESS_SECRET="generate-a-long-random-string-here"
JWT_REFRESH_SECRET="generate-another-long-random-string-here"

# 3. Server Configuration
PORT=5000
NODE_ENV="production"

# 4. Client URL (Important for CORS - Set to your Vercel URL)
CLIENT_URL="https://kod-lms-tau.vercel.app/"


